<Window x:Class="ESAPI_EQD2Viewer.UI.Views.StructureSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select structures for DVH analysis" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#222">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select structures:" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="StructureListBox" SelectionMode="Multiple"
                 Background="#1a1a1a" Foreground="White" BorderBrush="#555">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Id}" Foreground="White"
                              IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0"
                    Click="OK_Click" IsDefault="True" Background="#2d5a2d" Foreground="White"/>
            <Button Content="Cancel" Width="80" Height="28" IsCancel="True" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
