<Window x:Class="ESAPI_EQD2Viewer.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ESAPI_EQD2Viewer.UI.ViewModels"
        xmlns:controls="clr-namespace:ESAPI_EQD2Viewer.UI.Controls"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="ESAPI EQD2 Viewer" Height="950" Width="1300" Background="#111"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== MAIN CONTENT AREA (Left) ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="2*" MinHeight="150"/>
            </Grid.RowDefinitions>

            <!-- Isodose Viewer -->
            <controls:InteractiveImageViewer 
                Grid.Row="0" Margin="5"
                CtImageSource="{Binding CtImageSource}"
                DoseImageSource="{Binding DoseImageSource}"
                CurrentSlice="{Binding CurrentSlice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                MaxSlice="{Binding MaxSlice}"
                WindowLevel="{Binding WindowLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                WindowWidth="{Binding WindowWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#333"/>

            <!-- DVH + Summary Area -->
            <TabControl Grid.Row="2" Margin="5" Background="#1a1a1a" Foreground="White"
                        BorderBrush="#333" BorderThickness="1">
                
                <!-- DVH Tab -->
                <TabItem Header="DVH Chart" Background="#222" Foreground="White">
                    <oxy:PlotView Model="{Binding PlotModel}" Background="#1a1a1a" Margin="2"/>
                </TabItem>

                <!-- Summary Table Tab -->
                <TabItem Header="Summary" Background="#222" Foreground="White">
                    <DataGrid AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              ItemsSource="{Binding SummaryData}" Background="#1a1a1a"
                              Foreground="White" RowBackground="#1a1a1a" AlternatingRowBackground="#222"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333"
                              BorderBrush="#333" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Structure" Width="*" Binding="{Binding StructureId}"/>
                            <DataGridTextColumn Header="Plan" Width="Auto" Binding="{Binding PlanId}"/>
                            <DataGridTextColumn Header="Type" Width="Auto" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Dmax (Gy)" Width="Auto" Binding="{Binding DMax, StringFormat=F2}"/>
                            <DataGridTextColumn Header="Dmean (Gy)" Width="Auto" Binding="{Binding DMean, StringFormat=F2}"/>
                            <DataGridTextColumn Header="Dmin (Gy)" Width="Auto" Binding="{Binding DMin, StringFormat=F2}"/>
                            <DataGridTextColumn Header="Vol (cm³)" Width="Auto" Binding="{Binding Volume, StringFormat=F2}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ===== SIDE PANEL (Right) ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8" Background="#222">

                <!-- EQD2 Settings -->
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="EQD2 CONVERSION" Foreground="#FFD700" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <CheckBox Content=" Enable EQD2 isodose" IsChecked="{Binding IsEQD2Enabled}"
                                  Foreground="White" Margin="0,4"/>

                        <TextBlock Text="{Binding NumberOfFractions, StringFormat='Fractions: {0}'}"
                                   Foreground="White" Margin="0,8,0,0"/>
                        <Slider Minimum="1" Maximum="50" Value="{Binding NumberOfFractions}"
                                IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,2"/>

                        <TextBlock Text="{Binding GlobalAlphaBeta, StringFormat='Isodose α/β: {0:F1} Gy'}"
                                   Foreground="White" Margin="0,8,0,0"/>
                        <Slider Minimum="0.5" Maximum="20" Value="{Binding GlobalAlphaBeta}"
                                TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="0,2"/>

                        <CheckBox Content=" Differential Dmean" IsChecked="{Binding UseDifferentialMethod}"
                                  Foreground="White" Margin="0,8,0,0" ToolTip="More accurate for heterogeneous dose distributions"/>
                    </StackPanel>
                </Border>

                <!-- Structure α/β Settings -->
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="STRUCTURE α/β" Foreground="#FFD700" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <Button Content="Select Structures..." Click="SelectStructures_Click"
                                Margin="0,0,0,8" Padding="4"/>

                        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False"
                                  MaxHeight="200" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding StructureSettings}"
                                  Background="#1a1a1a" Foreground="White"
                                  RowBackground="#1a1a1a" AlternatingRowBackground="#222"
                                  HorizontalGridLinesBrush="#333" BorderBrush="#333">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#333"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Structure" IsReadOnly="True" Width="*"
                                                    Binding="{Binding Id}"/>
                                <DataGridTextColumn Header="α/β" Width="50"
                                                    Binding="{Binding AlphaBeta, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="Calculate EQD2 DVH" Command="{Binding CalculateEQD2Command}"
                                Margin="0,8,0,0" Padding="4" Background="#2d5a2d" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- DVH Display -->
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="DVH DISPLAY" Foreground="#FFD700" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <CheckBox Content=" Show physical DVH" IsChecked="{Binding ShowPhysicalDVH}"
                                  Foreground="White" Margin="0,2"/>
                        <CheckBox Content=" Show EQD2 DVH" IsChecked="{Binding ShowEQD2DVH}"
                                  Foreground="White" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <!-- Windowing -->
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="WINDOWING" Foreground="#FFD700" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <TextBlock Text="{Binding WindowLevel, StringFormat='Level: {0:F0}'}" Foreground="White"/>
                        <Slider Minimum="-1000" Maximum="1000" Value="{Binding WindowLevel}" Margin="0,2"/>

                        <TextBlock Text="{Binding WindowWidth, StringFormat='Width: {0:F0}'}" Foreground="White" Margin="0,6,0,0"/>
                        <Slider Minimum="1" Maximum="3000" Value="{Binding WindowWidth}" Margin="0,2"/>

                        <TextBlock Text="PRESETS" Foreground="Gray" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <Button Content="Soft Tissue" Command="{Binding PresetCommand}" CommandParameter="Soft" Margin="0,2" Padding="4"/>
                        <Button Content="Lung" Command="{Binding PresetCommand}" CommandParameter="Lung" Margin="0,2" Padding="4"/>
                        <Button Content="Bone" Command="{Binding PresetCommand}" CommandParameter="Bone" Margin="0,2" Padding="4"/>
                        <Button Content="AUTO" Command="{Binding AutoPresetCommand}" Margin="0,4" Padding="4"
                                Background="DarkGreen" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Isodose Legend -->
                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,5">
                    <StackPanel>
                        <TextBlock Text="ISODOSE LEVELS" Foreground="#FFD700" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding IsodoseLevels}" x:Name="IsodoseLegend">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Rectangle Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Label}" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Export and Debug -->
                <Button Content="Export CSV" Command="{Binding ExportCSVCommand}" Margin="0,10,0,2"
                        Padding="4" Background="#2d4a6d" Foreground="White"/>
                <Button Content="Export Debug" Command="{Binding DebugCommand}" Margin="0,2"
                        Padding="4" Background="DarkRed" Foreground="White"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== BOTTOM BAR ===== -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5" Background="#222">
            <TextBlock Text="Slice (Z):" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            <Slider Width="700" Margin="10,0"
                    Minimum="0" Maximum="{Binding MaxSlice}" Value="{Binding CurrentSlice}"
                    IsSnapToTickEnabled="True" TickFrequency="1"/>
            <TextBlock Text="{Binding StatusText}" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>
